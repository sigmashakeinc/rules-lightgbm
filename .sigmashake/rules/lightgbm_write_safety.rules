# lightgbm_write_safety.rules
# Technology: lightgbm | Capability: write

rule lightgbm-block-unsafe-patterns {
  enabled true
  priority 90
  severity error
  DENY write
  IF path GLOB "**/*" AND content CONTAINS "UNSAFE_lightgbm_PATTERN"
  MESSAGE "Blocked an unsafe pattern in lightgbm. Use the recommended best practices for 2025/2026."
}

rule lightgbm-force-updated-api {
  enabled true
  priority 80
  severity warning
  ASK write
  IF path GLOB "**/*" AND content CONTAINS "OLD_lightgbm_API"
  MESSAGE "You are using an outdated API for lightgbm. Please upgrade to the newer API."
}
